{
  "name": "@hellow/electron",
  "private": true,
  "version": "0.1.0",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @hellow/app dev\" \"wait-on http://localhost:5173 && pnpm build:main && electron .\"",
    "build:main": "tsc -p tsconfig.json",
    "build": "pnpm --filter @hellow/app build && pnpm build:main",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "wait-on": "^8.0.1"
  }
}
